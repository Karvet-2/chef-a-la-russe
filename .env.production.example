# Скопируйте в .env.production на сервере (файл в .gitignore).

NODE_ENV=production

# Managed PostgreSQL (Timeweb): строка из панели. При необходимости SSL:
# DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DB?schema=public&sslmode=require"
DATABASE_URL="postgresql://USER:PASSWORD@127.0.0.1:5432/chef_championship?schema=public"

JWT_SECRET="change-me-to-long-random-string"

# Опционально: отключить Tailwind Play CDN (в docker-compose по умолчанию включён резерв)
# TAILWIND_PLAY_CDN=0

# Показать ссылку сброса пароля прямо в ответе API (удобно без почты; на проде лучше выключить)
# PASSWORD_RESET_RETURN_LINK=1
