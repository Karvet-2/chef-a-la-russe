{
  "name": "chef-championship-2026",
  "version": "0.1.0",
  "private": true,
  "prisma": {
    "schema": "backend/prisma/schema.prisma"
  },
  "scripts": {
    "fill-frontend": "node scripts/move-layout.js",
    "dev": "node scripts/ensure-frontend.js && next dev ./frontend",
    "build": "node scripts/ensure-frontend.js && next build ./frontend",
    "start": "next start ./frontend",
    "lint": "node scripts/ensure-frontend.js && next lint ./frontend",
    "download-icons": "node scripts/download-figma-png.js",
    "create-organizer": "tsx scripts/create-organizer.ts",
    "create-admin": "tsx scripts/create-admin.ts",
    "db:studio": "prisma studio",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:push": "prisma db push",
    "db:reset": "prisma migrate reset",
    "db:check": "tsx scripts/check-db.ts",
    "db:users": "tsx scripts/list-users.ts",
    "db:seed": "tsx scripts/seed.ts",
    "docker:db:up": "docker compose -f docker/docker-compose.dev.yml up -d postgres",
    "docker:db:down": "docker compose -f docker/docker-compose.dev.yml down",
    "docker:db:logs": "docker compose -f docker/docker-compose.dev.yml logs -f postgres",
    "docker:studio": "docker compose -f docker/docker-compose.dev.yml --profile dev up prisma-studio",
    "docker:up": "docker compose -f docker/docker-compose.yml up -d --build",
    "docker:down": "docker compose -f docker/docker-compose.yml down",
    "docker:logs": "docker compose -f docker/docker-compose.yml logs -f app",
    "docker:restart": "docker compose -f docker/docker-compose.yml restart app",
    "docker:clean": "docker compose -f docker/docker-compose.yml down -v",
    "docker:prod:build": "docker compose -f docker-compose.prod.yml build",
    "docker:prod:up": "docker compose -f docker-compose.prod.yml up -d",
    "docker:prod:down": "docker compose -f docker-compose.prod.yml down",
    "docker:prod:logs": "docker compose -f docker-compose.prod.yml logs -f"
  },
  "dependencies": {
    "@prisma/client": "^6.0.0",
    "prisma": "^6.0.0",
    "bcryptjs": "^3.0.3",
    "jsonwebtoken": "^9.0.3",
    "next": "^14.0.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "devDependencies": {
    "@svgr/cli": "^8.1.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^20.0.0",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "autoprefixer": "^10.4.0",
    "eslint": "^8.0.0",
    "eslint-config-next": "^14.0.0",
    "postcss": "^8.4.0",
    "puppeteer": "^24.35.0",
    "sharp": "^0.34.5",
    "svg2img": "^1.0.0-beta.2",
    "tailwindcss": "^3.3.0",
    "tsx": "^4.21.0",
    "typescript": "^5.0.0"
  }
}
